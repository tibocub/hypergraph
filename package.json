{
  "name": "hypergraph",
  "version": "0.0.1",
  "description": "P2P graph store built on Hypercore/Autobase with a focus on ease of use.",
  "main": "index.js",
  "bin": {
    "hypergraph-inspect": "bin/hypergraph-inspector.js"
  },
  "scripts": {
    "test": "npm run test:core && npm run test:networking && npm run test:replication && npm run test:forum && npm run test:integration",
    "test:entities": "npx brittle test/brittle/core/entities.js",
    "test:events": "npx brittle test/brittle/core/events.js",
    "test:identity-manager": "npx brittle test/brittle/core/identity-manager.js test/brittle/core/identity-graph.js",
    "test:contexts": "npx brittle test/brittle/core/contexts.js",
    "test:view": "npx brittle test/brittle/core/view.js",
    "test:user-core": "npx brittle test/brittle/core/user-core.js",
    "test:error-cases": "npx brittle test/brittle/core/error-cases.js",
    "test:relations": "npx brittle test/brittle/core/relations.js",
    "test:tags": "npx brittle test/brittle/core/tags.js",
    "test:queries": "npx brittle test/brittle/core/query.js",
    "test:roles": "npx brittle test/brittle/core/roles.js",
    "test:moderation": "npx brittle test/brittle/core/moderation.js",
    "test:core": "npx brittle test/brittle/core/*.js",
    "test:hypergraph-network": "npx brittle test/brittle/networking/hypergraph-network.js",
    "test:connect-to-swarm": "npx brittle test/brittle/networking/connect-to-swarm.js",
    "test:peer-connection": "npx brittle test/brittle/networking/peer-connection.js",
    "test:bootstrap-export": "npx brittle test/brittle/networking/bootstrap-export.js",
    "test:networking": "npx brittle test/brittle/networking/*.js",
    "test:late-joiner": "npx brittle test/brittle/replication/late-joiner.js",
    "test:concurrent-writes": "npx brittle test/brittle/replication/concurrent-writes.js",
    "test:peer-reconnection": "npx brittle test/brittle/replication/peer-reconnection.js",
    "test:multi-peer": "npx brittle test/brittle/replication/multi-peer.js",
    "test:out-of-order": "npx brittle test/brittle/replication/out-of-order.js",
    "test:partial-replication": "npx brittle test/brittle/replication/partial-replication.js",
    "test:hypergraph-network-integration": "npx brittle test/brittle/replication/hypergraph-network-integration.js",
    "test:replication": "npx brittle test/brittle/replication/*.js",
    "test:forum": "npx brittle test/brittle/forum/index.js",
    "test:integration": "npx brittle test/brittle/integration/*.js",
    "populate:inspector": "node scripts/populate-inspector-fixture.js",
    "validate:roles": "node scripts/validate-roles.js",
    "forum:web:owner": "node examples/forum-web/peer.js --name=owner --role=owner --topic=hyper-bbs-forum-demo",
    "forum:web:peer": "node examples/forum-web/peer.js --name=peer --role=peer --topic=hyper-bbs-forum-demo",
    "docs": "jsdoc -c jsdoc.json"
  },
  "dependencies": {
    "autobase": "^7.28.1",
    "b4a": "^1.8.1",
    "codecs": "^3.1.0",
    "compact-encoding": "^3.0.1",
    "corestore": "^7.9.2",
    "hyperbee": "^2.27.3",
    "hypercore-crypto": "^3.7.0",
    "keet-identity-key": "^3.2.0"
  },
  "devDependencies": {
    "brittle": "^3.0.0",
    "hyperswarm": "^4.17.0",
    "random-access-memory": "^3.0.0"
  },
  "license": "MIT"
}
